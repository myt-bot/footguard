{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://footguard.local/schema/command-v1.json",
  "title": "FootGuard Device Command v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "command_id",
    "target",
    "pattern",
    "duration_ms",
    "expire_at_ms",
    "reason_code"
  ],
  "properties": {
    "protocol_version": {
      "type": "integer",
      "const": 1
    },
    "command_id": {
      "type": "string",
      "pattern": "^cmd_[A-Za-z0-9_-]{1,48}$"
    },
    "target": {
      "type": "string",
      "enum": ["left", "right", "both"]
    },
    "pattern": {
      "type": "string",
      "enum": ["off", "short", "double", "long"]
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5000
    },
    "expire_at_ms": {
      "type": "integer",
      "minimum": 0
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "manual_test",
        "left_load_bias",
        "right_load_bias",
        "forefoot_high",
        "risk_persisted",
        "cancel"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"pattern": {"const": "off"}},
        "required": ["pattern"]
      },
      "then": {
        "properties": {"duration_ms": {"type": "integer", "const": 0}}
      }
    },
    {
      "if": {
        "properties": {"pattern": {"const": "short"}},
        "required": ["pattern"]
      },
      "then": {
        "properties": {"duration_ms": {"type": "integer", "minimum": 100, "maximum": 1000}}
      }
    },
    {
      "if": {
        "properties": {"pattern": {"const": "double"}},
        "required": ["pattern"]
      },
      "then": {
        "properties": {"duration_ms": {"type": "integer", "minimum": 200, "maximum": 2000}}
      }
    },
    {
      "if": {
        "properties": {"pattern": {"const": "long"}},
        "required": ["pattern"]
      },
      "then": {
        "properties": {"duration_ms": {"type": "integer", "minimum": 1000, "maximum": 5000}}
      }
    }
  ]
}
